# Compose environment — copy to `.env` for local dev. These dev defaults are intentionally
# insecure and fine ONLY for localhost. Generate real secrets (>= 16 chars) for any deployment.
POSTGRES_USER=panvitium
POSTGRES_PASSWORD=panvitium
POSTGRES_DB=panvitium
DATABASE_URL=postgres://panvitium:panvitium@postgres:5432/panvitium
PUBLIC_URL=http://localhost:5173
COOKIE_SECRET=dev-insecure-cookie-secret-change-me
MAGIC_LINK_SECRET=dev-insecure-magic-secret-change-me
SAVE_SIGNING_SECRET=dev-insecure-save-secret-change-me
